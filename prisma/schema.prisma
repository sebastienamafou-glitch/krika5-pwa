// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Gestion des Rôles pour le Login Admin
enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum PaymentStatus {
  UNPAID
  PAID
}

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  password      String? // Hashé, requis uniquement pour ADMIN/STAFF
  role          Role     @default(CUSTOMER)
  loyaltyPoints Int      @default(0) // Compteur sécurisé pour la fidélité
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 2. Nouvel axe : Catégories (Menus, Boissons, Desserts)
model Category {
  id       String    @id @default(cuid())
  name     String    @unique // ex: "Boissons"
  slug     String    @unique // ex: "boissons"
  order    Int       @default(0) // Pour trier l'affichage dans le header
  products Product[]
}

// 3. Mise à jour du Produit : Stock et Catégorie
model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  stock       Int         @default(0) // Gestion de l'inventaire
  isAvailable Boolean     @default(true) // Bouton d'arrêt d'urgence si rupture
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Les commandes restent globalement inchangées pour l'instant
enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  DELIVERED
  CANCELLED
}

enum OrderType {
  TAKEAWAY // À emporter / Sur place
  DELIVERY // Livraison
}

model Order {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  totalAmount     Float
  status          OrderStatus   @default(PENDING)
  paymentMethod   String
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentStatus   PaymentStatus @default(UNPAID)
  orderType       OrderType     @default(TAKEAWAY)
  deliveryAddress String?
  deliveryLat     Float? // NOUVEAU : Latitude
  deliveryLng     Float? // NOUVEAU : Longitude       
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}
